---
import Layout from "@/layouts/Layout.astro";

const { title, description, ogImage } = Astro.props;
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType="website">
  <main class="p-4 max-w-3xl px-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <slot />
  </main>
</Layout>
