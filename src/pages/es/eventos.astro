---
import { getEvents } from "@/api/events";
import type { Event, EventsTranslation } from "@/api/types/events";
import Layout from "@/layouts/Layout.astro";

import type { Lang } from "@/i18n";
import EventCard from "@/components/ui/EventCard.astro";

const locale = Astro.currentLocale as Lang;

const events = await getEvents(locale);
---

<Layout title="Eventos" description="Eventos de PAD">
  <main class="">
    <!-- Heading -->
    <div
      class="text-default relative mx-auto max-w-5xl px-8 py-12 md:max-w-4xl md:px-10 md:py-14 lg:py-16">
      <div
        class="mb-4 max-w-2xl text-center md:mx-auto md:mb-12 md:max-w-4xl lg:max-w-5xl">
        <div>
          <span
            class="font-handwrite text-2xl font-semibold tracking-wider text-secondary md:text-3xl">
            Descubre cómo puedes ayudarnos
          </span>
          <h2
            class="mt-2 font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl">
            Eventos
          </h2>
        </div>
      </div><div
        class="text-md mx-auto grid gap-8 leading-normal sm:grid-cols-2 md:gap-y-12">
      </div>
    </div>

    <!-- Content -->
    <section class="w-full">
      <div class="relative mx-auto mb-20 max-w-5xl px-8 md:max-w-4xl md:px-14">
        <div class="grid gap-8 sm:grid-cols-2 sm:gap-y-8 md:gap-6">
          {
            events ? (
              events.map((event: Event) => (
                <EventCard
                  title={event.translations[0].title}
                  slug={event.translations[0].slug}
                  description={event.translations[0].description}
                  category={event.category}
                  cover={event.cover}
                  location={event.location}
                  datetime={event.datetime}
                />
              ))
            ) : (
              <div class="mx-auto text-center sm:col-span-2">
                Crea una página en la sección de "volunteer-page"
              </div>
            )
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
