---
import { getEvents } from "@/api/events";
import type { Event } from "@/api/types/events";
import Layout from "@/layouts/Layout.astro";

import type { Lang } from "@/i18n";
import EventCard from "@/components/ui/EventCard.astro";

const locale = Astro.currentLocale as Lang;

const events = await getEvents(locale);

const title =
  "Eventos Solidarios y Actividades de PAD &mdash; ¡Únete y Apoya a Nuestros Animales!";
const description =
  "Participa en los eventos solidarios de PAD y ayuda a mejorar la vida de nuestros animales. Descubre cómo puedes colaborar asistiendo a nuestras actividades, desde jornadas de adopción hasta eventos especiales. ¡Cada aporte cuenta para darles un hogar!";
---

<Layout title={title} description={description}>
  <main class="">
    <!-- Heading -->
    <div
      class="text-default relative mx-auto max-w-4xl px-8 py-12 md:px-10 md:py-14 lg:py-16">
      <div class="max-w-2xl text-center md:mx-auto md:max-w-4xl lg:max-w-5xl">
        <div>
          <span
            class="font-handwrite text-2xl font-semibold tracking-wider text-secondary md:text-3xl">
            Participa y ayuda a mejorar la vida de nuestros animales
          </span>
          <h2
            class="mt-2 font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl">
            Eventos Solidarios y Actividades
          </h2>
        </div>
      </div><div
        class="text-md mx-auto grid gap-8 leading-normal sm:grid-cols-2 md:gap-y-12">
      </div>
    </div>

    <!-- Content -->
    <section class="w-full">
      <div class="relative mx-auto mb-20 max-w-4xl px-8 md:px-10">
        <div class="grid grid-cols-1 items-start gap-8 sm:grid-cols-2 md:gap-6">
          {
            events ? (
              events.map((event: Event) => (
                <EventCard
                  title={event.translations[0].title}
                  slug={event.translations[0].slug}
                  description={event.translations[0].description}
                  category={event.category}
                  cover={event.cover}
                  address={event.address}
                  location={event.location}
                  price={event.price}
                  datetime={event.datetime}
                />
              ))
            ) : (
              <div class="mx-auto text-center sm:col-span-2">
                No hay eventos proximamente
              </div>
            )
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
