---
import ThemeLayout from "@/layouts/ThemeLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const themes = await getCollection("themes");

  return themes.map((theme) => {
    return {
      params: { slug: theme.slug },
      props: { theme },
    };
  });
}

const { theme } = Astro.props as { theme: CollectionEntry<"themes"> };

const { Content } = await theme.render();

console.log("theme.data.title");
console.log(theme.data.title);
---

<ThemeLayout title={theme.data.title} description={theme.data.description}>
  <Content />
</ThemeLayout>
