---
import Slider from "@/components/media/Slider.astro";
import ThemeBrowserLayout from "@/layouts/ThemeBrowserLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const themes = await getCollection("themes");

  return themes.map((theme) => {
    return {
      params: { slug: theme.slug },
      props: { theme },
    };
  });
}

const { theme } = Astro.props as { theme: CollectionEntry<"themes"> };

const { Content } = await theme.render();
---

<ThemeBrowserLayout
  title={theme.data.title}
  description={theme.data.description}
  ogImage={theme.data.cover}
  demoUrl={theme.data.demoUrl}
  price={theme.data.price}
  images={theme.data.images}>
  <Content />
</ThemeBrowserLayout>
