---
import ThemeCard from "../../components/ThemeCard.astro";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import Pagination from "../../components/Pagination.astro";
import type { GetStaticPathsOptions } from "astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const themes = (await getCollection("themes")).sort((a, b) => {
    return b.data.publishDate.getTime() - a.data.publishDate.getTime();
  });

  return paginate(themes, { pageSize: 9 });
}
// All paginated data is passed on the "page" prop
const { page } = Astro.props;
---

<Layout title="Themes">
  <main
    class="mx-auto flex flex-wrap items-center justify-between space-x-4 p-4 max-w-3xl px-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {page && page.data.map((theme) => <ThemeCard theme={theme} />)}
    </div>
  </main>
  <Pagination totalPages={page.data.length} />
</Layout>
