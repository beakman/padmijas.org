---
import ThemeCard from "@/components/ThemeCard.astro";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const themes = await getCollection("themes");
---

<Layout title="Themes">
  <main
    class="mx-auto flex flex-wrap items-center justify-between space-x-4 p-4 max-w-3xl px-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {themes.map((theme) => <ThemeCard theme={theme} />)}
    </div>
  </main>
</Layout>
