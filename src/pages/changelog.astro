---
import Button from "@/components/forms/Button.astro";
import Link from "@/components/ui/Link.astro";
import Pill from "@/components/ui/Pill.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const changelog = [
  {
    version: "2.5.1",
    date: "2024-07-25",
    entries: [
      {
        section: "Adds",
        items: [
          "Introduced a new user dashboard with enhanced analytics.",
          "Added support for multi-factor authentication (MFA).",
          "Implemented dark mode for the application interface.",
          "Added new filtering options in the data export feature.",
          "Included a notification center to keep users updated on important events.",
          "Integrated third-party payment gateway for seamless transactions.",
        ],
      },
      {
        section: "Fixes",
        items: [
          "Resolved issue where the application would crash on startup for some users.",
          "Fixed a bug that caused incorrect data to be displayed in the reports.",
          "Addressed an issue with the login form not validating email addresses correctly.",
          "Corrected a typo in the settings menu.",
          "Fixed broken links in the help documentation.",
        ],
      },
      {
        section: "Changes",
        items: [
          "Updated the user profile page layout for better usability.",
          "Changed the password reset process to enhance security.",
          "Modified the API endpoints to improve performance.",
          "Revised the terms of service and privacy policy.",
          "Updated the default application theme for a fresher look.",
        ],
      },
    ],
  },
  {
    version: "2.4.0",
    date: "2024-06-15",
    entries: [
      {
        section: "Adds",
        items: [
          "Added new chart types to the analytics dashboard.",
          "Implemented support for exporting data to CSV and Excel formats.",
          "Introduced a new feedback form for users to submit suggestions.",
          "Added a system status page to monitor service uptime.",
          "Integrated social media sharing options for user profiles.",
        ],
      },
      {
        section: "Fixes",
        items: [
          "Fixed a bug causing slow load times on the dashboard.",
          "Resolved an issue where notifications were not being sent properly.",
          "Addressed a problem with incorrect calculations in financial reports.",
          "Fixed a layout issue on the mobile version of the site.",
          "Corrected errors in the French localization files.",
        ],
      },
      {
        section: "Changes",
        items: [
          "Updated the login page with new branding.",
          "Reorganized the main menu for better navigation.",
          "Changed the default sorting order in the user list.",
          "Improved error messages to be more user-friendly.",
          "Updated the color scheme for better accessibility.",
        ],
      },
    ],
  },
  {
    version: "2.3.2",
    date: "2024-05-10",
    entries: [
      {
        section: "Adds",
        items: [
          "Introduced a bulk user import feature.",
          "Added detailed audit logs for user activities.",
          "Implemented a new REST API for third-party integrations.",
          "Included a new tutorial for first-time users.",
          "Added support for custom user roles and permissions.",
        ],
      },
      {
        section: "Fixes",
        items: [
          "Fixed an issue with file uploads failing intermittently.",
          "Resolved a bug where user avatars were not displaying correctly.",
          "Corrected an error in the subscription billing calculations.",
          "Fixed a security vulnerability in the password reset flow.",
          "Addressed an issue with the date picker not working in Firefox.",
        ],
      },
      {
        section: "Changes",
        items: [
          "Updated the email templates for transactional emails.",
          "Changed the layout of the admin dashboard.",
          "Improved the search functionality across the site.",
          "Updated the user guide with the latest features.",
          "Modified the default settings for new user accounts.",
        ],
      },
    ],
  },
  {
    version: "2.3.0",
    date: "2024-04-05",
    entries: [
      {
        section: "Adds",
        items: [
          "Added a new reporting module with customizable reports.",
          "Introduced an automated backup system for user data.",
          "Implemented a new API rate limiting feature.",
          "Included a new user onboarding process.",
          "Added support for multiple languages.",
        ],
      },
      {
        section: "Fixes",
        items: [
          "Fixed a bug causing session timeouts for some users.",
          "Resolved an issue with the email verification process.",
          "Corrected data synchronization issues with external systems.",
          "Fixed layout issues on the settings page.",
          "Addressed a problem with notifications not being marked as read.",
        ],
      },
      {
        section: "Changes",
        items: [
          "Updated the analytics engine for better performance.",
          "Changed the password strength requirements.",
          "Improved the layout of the user management page.",
          "Updated the design of the email notification templates.",
          "Modified the API documentation for clarity.",
        ],
      },
    ],
  },
  {
    version: "2.2.1",
    date: "2024-03-01",
    entries: [
      {
        section: "Adds",
        items: [
          "Added a new feature for scheduled tasks.",
          "Introduced an internal messaging system for users.",
          "Implemented real-time data synchronization.",
          "Included an option to export user activity logs.",
          "Added a new theme customization option.",
        ],
      },
      {
        section: "Fixes",
        items: [
          "Fixed an issue with the search bar not returning accurate results.",
          "Resolved a bug causing duplicated entries in the database.",
          "Corrected an error in the user registration form.",
          "Fixed a security issue related to user permissions.",
          "Addressed a problem with the file download functionality.",
        ],
      },
      {
        section: "Changes",
        items: [
          "Updated the navigation bar for better accessibility.",
          "Changed the default date format in reports.",
          "Improved the speed of data processing.",
          "Updated the FAQ section with new content.",
          "Modified the user session timeout settings.",
        ],
      },
    ],
  },
];
---

<Layout title="Support">
  <main
    class="mx-auto flex max-w-3xl flex-col p-4 px-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <section
      class="prose mx-auto w-full pt-16 dark:prose-invert prose-headings:my-0">
      <div
        class="flex w-full flex-col items-center justify-center gap-4 px-20 text-center">
        <Pill>Changelog</Pill>
        <h2 class="text-2xl font-bold md:text-4xl">
          New updates and improvements
        </h2>
        <p class="leading-relaxed text-muted-foreground">
          A latest-to-greatest list of our releases, packed with new features,
          improvements, and bug fixes
        </p>
      </div>
    </section>
    <section
      class="prose mx-auto w-full pt-16 dark:prose-invert prose-headings:my-0">
      <ul
        class="relative list-none border-s border-gray-200 dark:border-gray-700">
        {
          changelog &&
            changelog.map((item, index) => (
              <li class="mb-10 ms-6">
                <span class="absolute -start-5 flex h-10 w-10 items-center justify-center rounded-full bg-accent text-accent-foreground">
                  <Icon name="tabler:calendar" class="h-6 w-6" />
                </span>
                <h3 class="mb-1 flex items-center text-xl font-semibold text-gray-900 dark:text-white">
                  Release {item.version}
                  {index === 0 && (
                    <span class="me-2 ms-3 rounded bg-accent px-2.5 py-0.5 text-sm font-medium text-accent-foreground">
                      Latest
                    </span>
                  )}
                </h3>
                <time class="mb-2 block text-sm font-normal leading-none text-gray-400 dark:text-gray-500">
                  {item.date}
                </time>
                <p class="mb-4 text-base">
                  {item.entries.map((entry) => (
                    <span class="mb-2">
                      <h4 class="mb-1 flex items-center text-lg font-semibold">
                        {entry.section}
                      </h4>
                      <ul class="">
                        {entry.items &&
                          entry.items.map((item) => (
                            <li class="mb-2">
                              <span class="mr-1">{item}</span>
                            </li>
                          ))}
                      </ul>
                    </span>
                  ))}
                </p>
              </li>
            ))
        }
      </ul>
    </section>
  </main>
</Layout>
