---
export const prerender = false;
import { type Dogs } from "@/api/types/dog";
import type { QueryFilter } from "@directus/sdk";
import { getDogs, getDogsCounts } from "@/api/dogs";
import { Dog } from "@/api/types/dog";
import { Schema } from "@/api/client";
import Layout from "@/layouts/Layout.astro";
import PetCard from "@/components/ui/PetCard.astro";
import { type Lang, type Multilingual, DEFAULT_LOCALE } from "@/i18n";

const baseUrl: Multilingual = {
  es: "nuestros-perros",
  en: "our-dogs",
};

const currentPath = Astro.url.pathname;

const locale = Astro.currentLocale as Lang;
const translatedPath = `${baseUrl[locale] || baseUrl[DEFAULT_LOCALE]}`;

if (!currentPath.includes(translatedPath)) {
  return Astro.redirect(translatedPath);
}

const counts = await getDogsCounts();
const search: string = Astro.url.searchParams.get("search");
const status: string = Astro.url.searchParams.get("status") || "published";
const _status =
  status === "all" ? { _neq: "draft" } : { _nin: ["draft", "adopted"] };
const filters: { name: string; status: any } = {
  name: search,
  status: _status,
};

const filter: QueryFilter<Schema, Dog> = {
  ...(filters.name && {
    name: {
      _icontains: filters.name,
    },
  }),
  ...(filters.status && {
    status: filters.status,
  }),
};

const dogs = (await getDogs(filter)) as Dogs;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const search = data.get("search");
    const status = data.get("status");
    return Astro.redirect(`./?search=${search}&status=${status}`);
  } catch (error) {
    console.error(error);
  }
}

const title = "Dogs for Adoption 🐶 &mdash; Find Your Perfect Companion at PAD";
const description =
  "Discover our dogs available for adoption at PAD Mijas. Adopt your new best friend and give them a loving home.";
---

<Layout title={title} description={description}>
  <main
    class="mx-auto flex max-w-7xl flex-wrap items-center justify-between space-x-4 p-4 px-4 sm:px-6 md:max-w-4xl lg:px-8"
  >
    <section class="w-full">
      <div class="mb-2 mt-16 flex flex-col text-center">
        <h2
          class="font-handwrite text-2xl font-semibold tracking-wider text-secondary md:text-3xl"
        >
          Looking for a home
        </h2>
        <p
          class="mt-2 font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl"
        >
          Our dogs
        </p>
        <p class="mx-auto mt-5 max-w-prose text-lg text-gray-500 md:text-xl">
          Visit us regularly and meet our new arrivals
        </p>
      </div>

      <!-- Filters -->
      <div class="flex flex-col gap-4 md:flex-row">
        <form id="dogForm" class="mt-16 w-full" method="POST">
          <!-- Search -->
          <div class="relative mb-10">
            <label for="Search" class="sr-only"> Search </label>
            <input
              type="text"
              id="Search"
              name="search"
              value={search}
              placeholder="Search ..."
              class="w-full rounded-md border-2 border-gray-200 px-4 py-3 sm:text-sm"
            />
            <span
              class="absolute inset-y-0 right-1 grid w-10 place-content-center"
            >
              <button type="button" class="text-gray-600 hover:text-gray-700">
                <span class="sr-only">Search</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.75"
                  stroke="currentColor"
                  class="size-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
                  ></path>
                </svg>
              </button>
            </span>
          </div>
          <!-- / Search -->
          <!-- Status -->
          <fieldset class="flex flex-wrap items-center justify-center gap-3">
            <div>
              <label
                for="inAdoption"
                class="flex cursor-pointer items-center justify-center rounded-full border border-gray-100 bg-white px-3 py-2 text-gray-900 hover:border-gray-200 has-[:checked]:border-secondary has-[:checked]:bg-secondary has-[:checked]:text-white"
              >
                <input
                  type="radio"
                  name="status"
                  value="published"
                  id="inAdoption"
                  class="sr-only"
                  checked={status === "published"}
                />
                <span class="text-sm font-medium"
                  >In adoption ({counts.published + counts.reserved})</span
                >
              </label>
            </div>
            <div>
              <label
                for="allDogs"
                class="flex cursor-pointer items-center justify-center rounded-full border border-gray-100 bg-white px-3 py-2 text-gray-900 hover:border-gray-200 has-[:checked]:border-secondary has-[:checked]:bg-secondary has-[:checked]:text-white"
              >
                <input
                  type="radio"
                  name="status"
                  value="all"
                  id="allDogs"
                  class="sr-only"
                  checked={status === "all"}
                />
                <span class="text-sm font-medium"
                  >All ({
                    counts.published + counts.adopted + counts.reserved
                  })</span
                >
              </label>
            </div>
          </fieldset>
          <!-- Status -->
        </form>
        <script define:vars={{ search, status }}>
          const searchInput = document.getElementById("Search");
          const inAdoptionInput = document.getElementById("inAdoption");
          const allDogs = document.getElementById("allDogs");
          const form = document.getElementById("dogForm");

          searchInput.value = search;
          inAdoptionInput.checked = status === "published";
          allDogs.checked = status === "all";

          let debounceTimeout;

          searchInput.addEventListener("input", (event) => {
            const value = event.target.value;

            if (debounceTimeout) {
              clearTimeout(debounceTimeout);
            }

            debounceTimeout = setTimeout(() => {
              form.submit();
            }, 800); // Adjust the timeout duration as needed
          });

          inAdoptionInput.addEventListener("change", (event) => {
            form.submit();
          });

          allDogs.addEventListener("change", (event) => {
            form.submit();
          });
        </script>
      </div>

      <div
        class="grid w-full gap-4 px-10 py-12 sm:grid-cols-2 md:grid-cols-3 md:gap-8 md:px-0 md:py-14 lg:grid-cols-4"
      >
        {
          dogs.length > 0 ? (
            dogs.map((dog) => <PetCard dog={dog} />)
          ) : (
            <div class="col-span-4 items-center justify-center rounded-md bg-gray-100 p-4 text-center">
              <p class="text-lg font-semibold">We're sorry!</p>
              <p class="my-2 text-base">
                Your search did not return any results.
              </p>
            </div>
          )
        }
      </div>
    </section>
  </main>
</Layout>
