---
import { Image } from "astro:assets";
import { getPageBySlug, getPages } from "@/api/pages";
import type { Page, PagesTranslation } from "@/api/types/pages";
import Button from "@/components/forms/Button.astro";
import { LOCALES } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import { getAssetURL } from "@/api/client";
import type { Block } from "@/api/types/block";

export const getStaticPaths = async () => {
  const pages = await getPages();
  return Object.keys(LOCALES).flatMap((lang) =>
    pages.flatMap((page: Page) =>
      page.translations.map((translation: PagesTranslation) => ({
        params: {
          lang: lang,
          slug: translation.slug,
        },
      }))
    )
  );
};

const { lang, slug } = Astro.params;

// Get the page for this slug
const page = await getPageBySlug(slug, lang);

console.log("page", page);
if (!page) {
  return Astro.redirect("/404");
}
---

<Layout
  title={page.translations[0] && page.translations[0].title}
  description={page.translations[0] && page.translations[0].description}>
  <main class="">
    <!-- Main Hero Section -->
    <div>
      <!-- Hero card -->
      <div class="relative">
        <div class="w-full">
          <div class="relative shadow-xl sm:overflow-hidden">
            <div class="absolute inset-0">
              <Image
                src={getAssetURL(page.cover.id)}
                alt="Cover picture background"
                width={1065}
                height={235}
                class="h-full w-full object-cover"
              />
              <div class="absolute inset-0 bg-yellow-700 mix-blend-multiply">
              </div>
            </div>
            <div
              class="relative max-w-screen-sm px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-32">
              <h1
                class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
                <span
                  class="mb-2 block font-handwrite text-4xl font-light tracking-wide text-white md:mb-4 md:text-5xl"
                  >{
                    (page.translations[0] && page.translations[0].subtitle) ||
                      "Subtitle"
                  }</span
                >
                <span
                  class="block font-heading text-4xl font-bold uppercase leading-tight tracking-wide text-white md:text-6xl"
                  >{
                    (page.translations[0] && page.translations[0].title) ||
                      "Title"
                  }</span
                >
              </h1>
              {
                page.translations[0] && page.translations[0].cta && (
                  <div class="justify-startr mt-10 flex w-full sm:max-w-sm">
                    <div class="flex w-full flex-col items-center justify-start gap-4 md:flex-row">
                      <Button class="w-full md:w-auto" variant="default">
                        {page.translations[0].cta}
                      </Button>
                    </div>
                  </div>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <section class="w-full">
      <div class="pt-16 md:pt-20">
        <div class="relative mx-auto max-w-7xl px-4 sm:px-6 md:px-14">
          {
            page &&
              page.translations[0] &&
              page.translations[0].content &&
              page.translations[0].content.blocks.map((block: Block) => {
                if (block.type === "header") {
                  <h1 class="mt-2 text-center font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl">
                    {block.data.text}
                  </h1>;
                }
              })
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
