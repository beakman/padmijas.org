---
import Button from "@/components/Button.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Welcome to NoiceThemes.">
  <main
    class="mx-auto flex flex-wrap items-center justify-between space-x-4 p-4 max-w-3xl px-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <section
      class="mx-auto h-80 prose-headings:mb-1 flex flex-col items-center justify-center gap-4 w-full p-4 prose dark:prose-invert">
      <h1>Welcome to NoiceThemes.</h1>
      <p class="mt-0 text-center">
        NoiceThemes is a collection of free and premium <strong>Astro</strong> and
        <strong>Medusa</strong> templates for developers. Our goal is to provide
        a wide range of templates that are easy to use, customizable, and optimized
        for performance.
      </p>
      <div class="flex mx-auto items-center gap-4">
        <Button size="lg">View Themes</Button>
        <Button size="lg" variant="outline">Buy Themes</Button>
      </div>
    </section>
  </main>
</Layout>
