---
import { Image } from "astro:assets";
import Button from "@/components/Button.astro";
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";

interface Props {
  theme: CollectionEntry<"themes">;
}
const { theme } = Astro.props;
---

<div class="flex flex-col gap-4 w-full p-4">
  <a href={`/themes/${theme.slug}`}>
    <Image
      src={theme.data.cover}
      alt={theme.data.title}
      width={656}
      height={400}
      class="rounded-md hover:opacity-75"
      format="avif"
    />
  </a>
  <div class="flex gap-4 justify-between items-center">
    <h2 class="text-2xl font-semibold">{theme.data.title}</h2>
    <p class="text-lg md:text-2xl text-muted-foreground">${theme.data.price}</p>
  </div>
  <Button class="w-full md:w-auto text-center" variant="default">
    <a class="flex gap-2 items-center" href={`/themes/${theme.slug}`}>
      Buy now
      <Icon name="tabler:arrow-right" class="w-5 h-5" />
    </a>
  </Button>
</div>
