---
import Avatar from "./Avatar.astro";

import avatarImg from "assets/images/avatar.png";

interface Props {
  href?: string;
  name: string;
  handler?: string;
  message: string;
  class?: string;
}

const { name, handler, class: className = "" } = Astro.props;
---

<div
  class:list={[
    "mb-5 whitespace-normal text-wrap rounded-lg border border-foreground/20 p-5 font-light dark:border-foreground/10 dark:bg-foreground/5",
    className,
  ]}>
  <div class="mb-4 flex w-full items-center">
    <Avatar class="h-10 w-10" src={avatarImg} alt={name} />
    <div class="flex-grow pl-3">
      <h6 class="text-sm font-bold">{name}</h6>
      <span class="text-sm text-muted-foreground">
        {handler && <span class="text-muted-foreground">@{handler}</span>}
      </span>
    </div>
  </div>

  <div class="w-full">
    <p class="text-sm leading-tight">
      <span class="mr-1 text-lg font-bold italic leading-none text-gray-400"
        >"</span
      >Lorem ipsum dolor sit amet, consectetur adipisicing elit. Vitae,
      obcaecati ullam excepturi dicta error deleniti sequi.<span
        class="ml-1 text-lg font-bold italic leading-none text-gray-400">"</span
      >
    </p>
  </div>
</div>
