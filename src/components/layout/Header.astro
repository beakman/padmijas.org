---
import { mainMenu, socialLinks } from "@/config";
import Navbar from "@/components/navigation/Navbar.astro";
---

<header
  class="sticky top-0 z-30 mx-auto w-full flex-none border-slate-800 bg-primary px-3 py-3 drop-shadow-md transition-[opacity] ease-in-out dark:border-b dark:bg-transparent md:px-6">
  <Navbar
    mainMenuItems={mainMenu}
    socialLinks={socialLinks}
    showThemeSwitcher={false}
    showLanguageSelector={true}
  />
</header>
