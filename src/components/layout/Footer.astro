---
import Logo from "@/components/ui/Logo.astro";
import type { MenuItemProps, FooterItemsProps, SocialItemProps } from "@/types";
import Social from "@/components/ui/Social.astro";
import { footerLinks, siteMeta, socialLinks } from "@/config";
---

<footer class="px-0 py-10 border-t-2">
  <div
    class="flex flex-wrap items-center justify-between max-w-3xl p-4 px-4 mx-auto space-x-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <div class="w-full">
      <div class="mb-6">
        <a
          aria-label="Template logo"
          href="https://themes.noice.store"
          class="flex items-center">
          <Logo href="/" />
        </a>
      </div>
      <div
        class="grid grid-cols-2 lg:grid-flow-col auto-cols-fr gap-y-8 sm:gap-6">
        {
          footerLinks &&
            footerLinks.map((link: FooterItemsProps) => (
              <div>
                <h2 class="mb-6 text-sm font-semibold uppercase">
                  {link.section}
                </h2>
                <ul class="">
                  {link.links.map((link: MenuItemProps) => (
                    <li class="mb-4">
                      <a
                        href={link.href}
                        class="hover:underline"
                        target={link.target}>
                        {link.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
        }
      </div>
    </div>
  </div>
  <hr class="my-6 sm:mx-auto lg:my-8" />
  <div
    class="flex flex-wrap items-center justify-between max-w-3xl p-4 px-4 mx-auto space-x-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <div
      class="flex flex-col w-full gap-4 sm:flex-row sm:items-center sm:justify-between">
      <span class="order-2 text-sm text-center sm:order-1 sm:text-left"
        >© 2024 <a href={siteMeta.baseUrl} class="hover:underline"
          >{siteMeta.title}</a
        >. All Rights Reserved.
      </span>
      <div
        class="flex order-1 mx-auto mt-4 space-x-6 sm:mx-0 sm:order-2 sm:mt-0 sm:justify-center">
        {socialLinks && <Social socialLinks={socialLinks} />}
      </div>
    </div>
  </div>
</footer>
