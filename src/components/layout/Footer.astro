---
import Logo from "@/components/ui/Logo.astro";
import Social from "@/components/ui/Social.astro";
import { footerLinks, siteMeta, socialLinks } from "@/config";
import MinistryDisclaimer from "@/components/ui/MinistryDisclaimer.astro";
import { useTranslations, type Lang } from "@/i18n";
import { Icon } from "astro-icon/components";
import { getRelativeLocaleUrl } from "astro:i18n";

const t = useTranslations(Astro.currentLocale as Lang);
const locale = Astro.currentLocale as Lang;
---

<footer class="border-t-2 px-0 py-10">
  <div
    class="mx-auto flex max-w-3xl flex-wrap items-center justify-between space-x-4 p-4 px-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <div class="w-full">
      <div class="mb-6">
        <a
          aria-label="Template logo"
          href="https://themes.noice.store"
          class="flex items-center">
          <Logo href="/" />
        </a>
      </div>
      <div
        class="grid auto-cols-fr grid-cols-2 gap-y-8 sm:gap-6 lg:grid-flow-col">
        {
          footerLinks &&
            footerLinks.map((link) => (
              <div>
                <h2 class="mb-6 text-sm font-semibold uppercase">
                  {t(link.section)}
                </h2>
                <ul class="">
                  {link.items &&
                    link.items.map((item: any) => (
                      <li class="mb-4 text-xs md:text-base">
                        {item.type === "link" && (
                          <a
                            href={
                              t(item.href).startsWith("http") ||
                              t(item.href).startsWith("mailto")
                                ? t(item.href)
                                : getRelativeLocaleUrl(locale, t(item.href))
                            }
                            class="hover:underline"
                            target={item.target}>
                            {t(item.text)}
                          </a>
                        )}
                        {item.type === "text" && (
                          <p class="md:text-md text-sm text-muted">
                            {t(item.text)}
                          </p>
                        )}
                        {item.type === "icon" && (
                          <a
                            href={
                              t(item.href).startsWith("http")
                                ? t(item.href)
                                : getRelativeLocaleUrl(locale, t(item.href))
                            }
                            class="flex items-center gap-1 hover:underline">
                            <Icon
                              name={item.icon}
                              class="h-5 w-5 text-foreground"
                            />
                            <span>{t(item.text)}</span>
                          </a>
                        )}
                      </li>
                    ))}
                </ul>
              </div>
            ))
        }
      </div>
    </div>
  </div>
  <hr class="my-6 sm:mx-auto lg:my-8" />
  <MinistryDisclaimer />

  <!-- <div
    class="mx-auto flex max-w-3xl flex-wrap items-center justify-between space-x-4 p-4 px-4 sm:px-6 lg:max-w-6xl lg:px-8 xl:max-w-7xl">
    <div
      class="flex w-full flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <span class="order-2 text-center text-sm sm:order-1 sm:text-left"
        >© 2024 <a href={siteMeta.baseUrl} class="hover:underline"
          >{siteMeta.title}</a
        >. All Rights Reserved.
      </span>
      <div
        class="order-1 mx-auto mt-4 flex space-x-6 sm:order-2 sm:mx-0 sm:mt-0 sm:justify-center">
        {socialLinks && <Social socialLinks={socialLinks} />}
      </div>
    </div>
  </div> -->
</footer>
