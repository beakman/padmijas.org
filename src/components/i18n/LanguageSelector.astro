---
import { getLocalePaths, LOCALES } from "@/i18n";
---

<label
  class="flex items-center justify-start gap-2 rounded-md bg-transparent text-xl font-medium leading-tight md:text-sm">
  <select class="bg-transparent" data-languageSelect>
    {
      getLocalePaths(Astro.url).map(({ lang }) => {
        return (
          <option
            label={LOCALES[lang].label}
            value={`/${lang}/`}
            data-lang={lang}
            selected={lang === Astro.currentLocale}
            dir={LOCALES[lang].dir || null}>
            {lang}
          </option>
        );
      })
    }
  </select>
</label>

<script is:inline>
  document.querySelectorAll("[data-languageSelect]").forEach((select) => {
    select.addEventListener("change", (event) => {
      // used for 404 page
      localStorage.selectedLang = event.target?.selectedOptions[0].dataset.lang;
      location.href = event.target?.value;
    });
  });
</script>
