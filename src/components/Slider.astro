---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  images: ImageMetadata[];
  title: string;
}

const { images, title } = Astro.props;
---

<div class="flex flex-col gap-2 items-center">
  <div class="flex flex-col items-center">
    <div
      class="flex overflow-x-scroll snap-x snap-mandatory scroll-smooth touch-pan-x aspect-video rounded-md w-full">
      {
        images &&
          images.map((image, index) => (
            <Image
              class="w-full snap-always snap-start"
              src={image}
              alt={title}
              id={`slide${index + 1}`}
              width={1600}
              height={900}
            />
          ))
      }
    </div>
  </div>
  <div class="flex">
    {
      images &&
        images.map((image, index) => (
          <a
            href={`#slide${index + 1}`}
            class="w-3 h-3 mx-1 bg-foreground/60 hover:bg-foreground rounded-full"
          />
        ))
    }
  </div>
</div>
