---
import { Icon } from "astro-icon/components";
import Button from "@/components/Button.astro";
---

<Button
  data-theme-toggle
  type="button"
  variant="ghost"
  class="w-full md:w-auto">
  <Icon
    class="theme-toggle-icon h-6 w-6 opacity-100 transition"
    name="tabler:moon"
  />
  <Icon
    class="theme-toggle-icon hidden h-6 w-6 opacity-0 transition"
    name="tabler:sun"
  />
</Button>

<script>
  const setTheme = (theme: string) => {
    if (theme === "light") {
      document.documentElement.classList.remove("dark");
    } else {
      document.documentElement.classList.add("dark");
    }
    theme && window.localStorage.setItem("theme", theme);
  };

  function getTheme(): string {
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme") || "light";
    }
    if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
      return "dark";
    }
    return "light";
  }

  const handleToggleTheme = () => {
    const icon = document.querySelectorAll(".theme-toggle-icon");
    const element = document.documentElement;
    element.classList.toggle("dark");
    const isDark = element.classList.contains("dark");
    setTheme(isDark ? "dark" : "light");
    icon.forEach((icon) => {
      icon.classList.toggle("rotate-360");
      icon.classList.toggle("hidden");
      icon.classList.toggle("opacity-100");
      icon.classList.toggle("opacity-0");
    });
  };

  const theme = getTheme();
  setTheme(theme);
  const themeToggler = document.querySelectorAll("[data-theme-toggle]");
  themeToggler.forEach((toggler) => {
    toggler.addEventListener("click", handleToggleTheme);
  });

  document.addEventListener("astro:page-load", () => {
    const theme = getTheme();
    setTheme(theme);

    const themeToggler = document.querySelectorAll("[data-theme-toggle]");
    themeToggler.forEach((toggler) => {
      toggler.addEventListener("click", handleToggleTheme);
    });
  });

  document.addEventListener("astro:after-swap", () => {
    localStorage.theme === "dark"
      ? document.documentElement.classList.add("dark")
      : document.documentElement.classList.remove("dark");
  });

  document.addEventListener("astro:before-swap", (ev) => {
    // Pass the incoming document to set the theme on it
    const theme = getTheme();
    setTheme(theme);
  });
</script>
